package-as: DragonDice
enable-toc-creation: yes
manual-changelog: CHANGELOG.md

move-folders:
  DragonDice/DragonDice: DragonDice

externals:
  DragonDice/Libs/DragonCore: https://github.com/Xerrion/DragonCore

ignore:
  - .editorconfig
  - .git*
  - .luacheckrc
  - .luarc.json
  - .busted
  - "*.md"
  - "!CHANGELOG.md"
  - assets
  - spec
  - AGENTS.md
  - release-please-config.json
  - .release-please-manifest.json
